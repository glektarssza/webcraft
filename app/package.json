{
    "name": "webcraft",
    "description": "A simple Minecraft clone written in TypeScript using WebGL.",
    "version": "0.0.0",
    "license": "MIT",
    "private": true,
    "author": {
        "name": "G'lek Tarssza",
        "email": "glek@glektarssza.com",
        "url": "https://glektarssza.com"
    },
    "homepage": "https://glektarssza.github.io/webcraft/",
    "bugs": {
        "url": "https://github.com/glektarssza/webcraft/issues"
    },
    "repository": {
        "type": "git",
        "directory": "./app/",
        "url": "https://github.com/glektarssza/webcraft"
    },
    "scripts": {
        "test": "pnpm run test:ci",
        "test:ci": "karma start --single-run --browsers ChromeHeadless",
        "test:watch": "pnpm run test:base --single-run --browsers ChromeHeadless --auto-watch",
        "test:debug": "pnpm run test:base start",
        "test:base": "karma",
        "lint": "pnpm run lint:cache ./src/ts/ ./tests/",
        "lint:cache": "pnpm run lint:base --cache",
        "lint:base": "eslint --ext .tsx,.ts,.jsx,.js",
        "dev": "webpack serve --config ./webpack.config.dev.ts",
        "build": "pnpm run build:prod",
        "build:all": "pnpm run build:dev && pnpm run build:prod",
        "build:dev": "webpack build --config ./webpack.config.dev.ts",
        "build:prod": "webpack build --config ./webpack.config.prod.ts",
        "clean": "pnpm run clean:prod",
        "clean:all": "pnpm run clean:dev && pnpm run clean:prod",
        "clean:dev": "rimraf ./dist/dev/",
        "clean:prod": "rimraf ./dist/prod/",
        "rebuild": "pnpm run rebuild:prod",
        "rebuild:all": "pnpm run rebuild:dev && pnpm run rebuild:prod",
        "rebuild:dev": "pnpm run clean:dev && pnpm run build:dev",
        "rebuild:prod": "pnpm run clean:prod && pnpm run build:prod"
    },
    "dependencies": {
        "webcraft-common": "workspace:^0.0.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^8.3.1",
        "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
        "@types/chai": "^4.3.11",
        "@types/karma": "^6.3.8",
        "@types/mocha": "^10.0.6",
        "@types/node": "^20.10.4",
        "@types/sinon": "^17.0.2",
        "@types/sinon-chai": "^3.2.12",
        "@types/webpack": "^5.28.5",
        "@typescript-eslint/eslint-plugin": "^6.13.2",
        "@typescript-eslint/parser": "^6.13.2",
        "chai": "^4.3.10",
        "css-loader": "^6.8.1",
        "cssnano": "^6.0.2",
        "eslint": "^8.55.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "eslint-plugin-tsdoc": "^0.2.17",
        "eslint-webpack-plugin": "^4.0.1",
        "fork-ts-checker-webpack-plugin": "^9.0.2",
        "karma": "^6.4.2",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage-istanbul-reporter": "^3.0.3",
        "karma-mocha": "^2.0.1",
        "karma-sourcemap-loader": "^0.4.0",
        "karma-spec-reporter": "^0.0.36",
        "karma-webpack": "^5.0.0",
        "mocha": "^10.2.0",
        "postcss": "^8.4.32",
        "postcss-loader": "^7.3.3",
        "prettier": "^3.1.0",
        "pug-plugin": "^4.9.9",
        "puppeteer": "^21.6.1",
        "rimraf": "^5.0.5",
        "sass": "^1.69.5",
        "sass-loader": "^13.3.2",
        "sinon": "^17.0.1",
        "sinon-chai": "^3.7.0",
        "source-map-loader": "^4.0.1",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths-webpack-plugin": "^4.1.0",
        "typescript": "^5.3.3",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.1",
        "webpack-merge": "^5.10.0"
    }
}
