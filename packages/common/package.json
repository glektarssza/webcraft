{
    "name": "webcraft-common",
    "description": "Common code for the Webcraft project.",
    "version": "0.0.0",
    "license": "MIT",
    "private": true,
    "author": {
        "name": "G'lek Tarssza",
        "email": "glek@glektarssza.com",
        "url": "https://glektarssza.com"
    },
    "homepage": "https://glektarssza.github.io/webcraft/",
    "bugs": {
        "url": "https://github.com/glektarssza/webcraft/issues"
    },
    "repository": {
        "type": "git",
        "directory": "./app/",
        "url": "https://github.com/glektarssza/webcraft"
    },
    "main": "./dist/prod/webcraft-common.min.js",
    "module": "./lib/index.js",
    "exports": {
        "development": "./dist/dev/webcraft-common.js",
        "types": "./types/index.d.ts",
        "default": "./dist/prod/webcraft-common.min.js"
    },
    "scripts": {
        "test": "pnpm run test:ci",
        "test:ci": "karma start --single-run --browsers ChromeHeadless",
        "test:watch": "pnpm run test:base start --browsers ChromeHeadless --auto-watch",
        "test:debug": "pnpm run test:base start",
        "test:base": "karma",
        "lint": "pnpm run lint:cache ./src/ ./tests/",
        "lint:cache": "pnpm run lint:base --cache",
        "lint:base": "eslint --ext .tsx,.ts,.jsx,.js",
        "dev": "webpack serve --config ./webpack.config.dev.ts",
        "build": "pnpm run build:all",
        "build:all": "pnpm run build:lib && pnpm run build:types && pnpm run build:dev && pnpm run build:prod",
        "build:lib": "tsc --project ./src/tsconfig.json --outDir ./lib/",
        "build:types": "tsc --project ./src/tsconfig.json --declaration --emitDeclarationOnly --declarationDir ./types/",
        "build:dev": "webpack build --config ./webpack.config.dev.ts",
        "build:prod": "webpack build --config ./webpack.config.prod.ts",
        "clean": "pnpm run clean:prod",
        "clean:all": "pnpm run clean:dev && pnpm run clean:prod",
        "clean:lib": "rimraf ./lib/",
        "clean:types": "rimraf ./types/",
        "clean:dev": "rimraf ./dist/dev/",
        "clean:prod": "rimraf ./dist/prod/",
        "rebuild": "pnpm run rebuild:all",
        "rebuild:all": "pnpm run clean:all && pnpm run build:all",
        "rebuild:lib": "pnpm run clean:lib && pnpm run build:lib",
        "rebuild:types": "pnpm run clean:types && pnpm run build:types",
        "rebuild:dev": "pnpm run clean:dev && pnpm run build:dev",
        "rebuild:prod": "pnpm run clean:prod && pnpm run build:prod"
    },
    "devDependencies": {
        "@faker-js/faker": "^8.3.1",
        "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
        "@types/chai": "^4.3.11",
        "@types/karma": "^6.3.8",
        "@types/mocha": "^10.0.6",
        "@types/node": "^20.10.7",
        "@types/sinon": "^17.0.2",
        "@types/sinon-chai": "^3.2.12",
        "@types/webpack": "^5.28.5",
        "@types/webpack-node-externals": "^3.0.4",
        "@typescript-eslint/eslint-plugin": "^6.18.0",
        "@typescript-eslint/parser": "^6.18.0",
        "chai": "^4.3.10",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.2",
        "eslint-plugin-tsdoc": "^0.2.17",
        "eslint-webpack-plugin": "^4.0.1",
        "fork-ts-checker-webpack-plugin": "^9.0.2",
        "karma": "^6.4.2",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage-istanbul-reporter": "^3.0.3",
        "karma-mocha": "^2.0.1",
        "karma-sourcemap-loader": "^0.4.0",
        "karma-spec-reporter": "^0.0.36",
        "karma-webpack": "^5.0.0",
        "mocha": "^10.2.0",
        "prettier": "^3.1.1",
        "puppeteer": "^21.7.0",
        "rimraf": "^5.0.5",
        "sinon": "^17.0.1",
        "sinon-chai": "^3.7.0",
        "source-map-loader": "^4.0.2",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths-webpack-plugin": "^4.1.0",
        "typescript": "^5.3.3",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.1",
        "webpack-merge": "^5.10.0",
        "webpack-node-externals": "^3.0.0"
    }
}
